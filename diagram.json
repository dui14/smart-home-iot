{
  "version": 1,
  "author": "SmartHome ESP32 + 2 Relay + 2 LED Load",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-servo", "id": "servoDoor", "top": -120, "left": 280, "attrs": {} },
    { "type": "wokwi-relay-module", "id": "relay1", "top": 0.2, "left": 201.6, "attrs": {} },
    {
      "type": "wokwi-led",
      "id": "led1",
      "top": -42,
      "left": 464.6,
      "attrs": { "color": "green" }
    },
    {
      "type": "wokwi-resistor",
      "id": "rLoad1",
      "top": 32.75,
      "left": 422.4,
      "attrs": { "value": "220" }
    },
    { "type": "wokwi-relay-module", "id": "relay2", "top": 153.8, "left": 192, "attrs": {} },
    {
      "type": "wokwi-led",
      "id": "led2",
      "top": 111.6,
      "left": 474.2,
      "attrs": { "color": "blue" }
    },
    {
      "type": "wokwi-resistor",
      "id": "rLoad2",
      "top": 186.35,
      "left": 393.6,
      "attrs": { "value": "220" }
    },
    { "type": "wokwi-dht22", "id": "dht", "top": 67.5, "left": -283.8, "attrs": {} },
    {
      "type": "wokwi-resistor",
      "id": "rDht",
      "top": 291.95,
      "left": -172.8,
      "attrs": { "value": "4.7k" }
    },
    {
      "type": "wokwi-lcd1602",
      "id": "lcd",
      "top": -220,
      "left": -360,
      "attrs": { "pins": "i2c", "i2cAddress": "0x27" }
    }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    [ "servoDoor:PWM", "esp:D13", "orange", [] ],
    [ "servoDoor:V+", "esp:VIN", "red", [] ],
    [ "servoDoor:GND", "esp:GND.1", "black", [] ],
    [ "relay1:VCC", "esp:VIN", "red", [] ],
    [ "relay1:GND", "esp:GND.1", "black", [] ],
    [ "relay1:IN", "esp:D18", "green", [] ],
    [ "relay1:COM", "esp:VIN", "red", [] ],
    [ "relay1:NO", "rLoad1:1", "green", [] ],
    [ "rLoad1:2", "led1:A", "green", [] ],
    [ "led1:C", "esp:GND.1", "black", [ "v-9.6", "h-335.6", "v158.6" ] ],
    [ "relay2:VCC", "esp:VIN", "red", [] ],
    [ "relay2:GND", "esp:GND.1", "black", [] ],
    [ "relay2:IN", "esp:D19", "green", [] ],
    [ "relay2:COM", "esp:VIN", "red", [] ],
    [ "relay2:NO", "rLoad2:1", "green", [] ],
    [ "rLoad2:2", "led2:A", "green", [] ],
    [ "led2:C", "esp:GND.1", "black", [ "h-28.4", "v-9.6", "h-359.5" ] ],
    [ "dht:VCC", "esp:3V3", "red", [] ],
    [ "dht:GND", "esp:GND.1", "black", [] ],
    [ "dht:SDA", "esp:D15", "green", [] ],
    [ "rDht:1", "dht:SDA", "green", [] ],
    [ "rDht:2", "dht:VCC", "red", [] ],
    [ "lcd:VCC", "esp:VIN", "red", [] ],
    [ "lcd:GND", "esp:GND.1", "black", [] ],
    [ "lcd:SDA", "esp:D21", "green", [] ],
    [ "lcd:SCL", "esp:D22", "green", [] ]
  ],
  "serialMonitor": { "display": "always", "newline": "lf" },
  "dependencies": {}
}